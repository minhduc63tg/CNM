<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
    <link rel="stylesheet" href="./index.css" />
    <title>Quản lý Sản phẩm</title>
</head>

<body class="bg-light">
    <div class="container py-5">
        <div class="content card shadow-sm p-4 mb-5 bg-white">


            <hr />

            <div class="form-section mb-5">
                <h3 class="mb-4">Thêm sản phẩm mới</h3>
                <form id="addProductForm" action="/products" method="post" enctype="multipart/form-data" class="row">
                    <div class="form-group col-md-6 mb-3">
                        <label for="name font-weight-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input class="form-control" type="text" id="name" name="name" placeholder="VD: Kẹo sữa" required
                            minlength="3" maxlength="100" />
                        <small class="form-text text-muted">Từ 3-100 ký tự</small>
                        <div class="invalid-feedback">Tên sản phẩm phải từ 3-100 ký tự</div>
                    </div>
                    <div class="form-group col-md-6 mb-3">
                        <label for="price">Giá <span class="text-danger">*</span></label>
                        <input class="form-control" type="number" id="price" name="price" placeholder="VD: 60000"
                            required min="1000" max="999999999" step="1000" />
                        <small class="form-text text-muted">Giá tối thiểu: 1,000 VNĐ</small>
                        <div class="invalid-feedback">Giá phải là số dương từ 1,000 VNĐ trở lên</div>
                    </div>
                    <div class="form-group col-md-4 mb-3">
                        <label for="quantity">Số lượng tồn <span class="text-danger">*</span></label>
                        <input class="form-control" type="number" id="quantity" name="quantity" placeholder="VD: 30"
                            required min="0" max="999999" />
                        <small class="form-text text-muted">Số nguyên từ 0 trở lên</small>
                        <div class="invalid-feedback">Số lượng phải là số nguyên không âm</div>
                    </div>

                    <div class="form-group col-md-4 mb-3">
                        <label for="image">Hình ảnh sản phẩm <span class="text-danger">*</span></label>
                        <input class="form-control-file" type="file" id="image" name="image" required
                            accept="image/jpeg,image/png,image/jpg,image/gif,image/webp" />
                        <small class="form-text text-muted">JPG, PNG, GIF, WEBP (Tối đa 5MB)</small>
                        <div class="invalid-feedback">Vui lòng chọn file ảnh hợp lệ (JPG, PNG, GIF, WEBP)</div>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fa fa-plus"></i> Thêm sản phẩm
                        </button>
                    </div>
                </form>
            </div>

            <hr />

            <h2 class="title mb-4">Danh sách sản phẩm</h2>

            <!-- Search Box -->
            <div class="mb-3">
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-primary text-white">
                            <i class="fa fa-search"></i>
                        </span>
                    </div>
                    <input type="text" id="searchInput" class="form-control"
                        placeholder="Tìm kiếm theo tên sản phẩm..." />
                </div>
                <small class="form-text text-muted mt-1">
                    <span id="searchCount"></span>
                </small>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered" id="products">
                    <thead class="thead-dark text-center">
                        <tr>
                            <th>Id</th>
                            <th>Tên sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng tồn</th>

                            <th>Hình ảnh</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="align-middle text-center">
                        <% if (typeof products !=='undefined' && products.length> 0) { %>
                            <% products.forEach(function(product, index) { %>
                                <tr>
                                    <td><strong>
                                            <%= index + 1 %>
                                        </strong></td>
                                    <td>
                                        <%= product.name %>
                                    </td>
                                    <td><span class="badge badge-info">
                                            <%= product.price %>
                                        </span></td>
                                    <td>
                                        <%= product.quantity %>
                                    </td>

                                    <td>
                                        <img src="<%= product.image %>" alt="image"
                                            style="width: 70px; height: 70px; object-fit: cover;"
                                            class="img-thumbnail" />
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center">
                                            <a href="/products/<%= product.id %>" class="btn btn-sm btn-primary mr-2">
                                                <i class="fa fa-pencil"></i> Sửa
                                            </a>
                                            <form action="/products/delete/<%= product.id %>" method="POST"
                                                onsubmit="return confirm('Bạn có chắc chắn muốn xóa môn học này không?');">
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="fa fa-trash"></i> Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center py-4 text-muted">Chưa có sản phẩm nào
                                                trong danh sách.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Validation cho form thêm sản phẩm
        document.addEventListener('DOMContentLoaded', function () {
            const addForm = document.getElementById('addProductForm');

            if (addForm) {
                addForm.addEventListener('submit', function (e) {
                    const nameInput = document.getElementById('name');
                    const priceInput = document.getElementById('price');
                    const quantityInput = document.getElementById('quantity');
                    const imageInput = document.getElementById('image');

                    let isValid = true;
                    let errorMessages = [];

                    // Validate tên sản phẩm
                    const name = nameInput.value.trim();
                    if (name.length < 3 || name.length > 100) {
                        isValid = false;
                        errorMessages.push('Tên sản phẩm phải từ 3-100 ký tự');
                        nameInput.classList.add('is-invalid');
                    } else {
                        nameInput.classList.remove('is-invalid');
                    }

                    // Validate giá
                    const price = parseFloat(priceInput.value);
                    if (isNaN(price) || price < 1000) {
                        isValid = false;
                        errorMessages.push('Giá phải là số dương từ 1,000 VNĐ trở lên');
                        priceInput.classList.add('is-invalid');
                    } else {
                        priceInput.classList.remove('is-invalid');
                    }

                    // Validate số lượng
                    const quantity = parseInt(quantityInput.value);
                    if (isNaN(quantity) || quantity < 0 || !Number.isInteger(quantity)) {
                        isValid = false;
                        errorMessages.push('Số lượng tồn phải là số nguyên không âm');
                        quantityInput.classList.add('is-invalid');
                    } else {
                        quantityInput.classList.remove('is-invalid');
                    }

                    // Validate hình ảnh
                    if (imageInput.files.length > 0) {
                        const file = imageInput.files[0];
                        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
                        const maxSize = 5 * 1024 * 1024; // 5MB

                        if (!allowedTypes.includes(file.type)) {
                            isValid = false;
                            errorMessages.push('Chỉ chấp nhận file ảnh định dạng JPG, PNG, GIF, WEBP');
                            imageInput.classList.add('is-invalid');
                        } else if (file.size > maxSize) {
                            isValid = false;
                            errorMessages.push('Kích thước file ảnh không được vượt quá 5MB');
                            imageInput.classList.add('is-invalid');
                        } else {
                            imageInput.classList.remove('is-invalid');
                        }
                    }

                    if (!isValid) {
                        e.preventDefault();
                        alert('Vui lòng kiểm tra lại dữ liệu nhập:\n\n' + errorMessages.join('\n'));
                        return false;
                    }
                });
            }

            // Tìm kiếm sản phẩm theo tên
            const searchInput = document.getElementById('searchInput');
            const table = document.getElementById('products');
            const tbody = table.getElementsByTagName('tbody')[0];
            const rows = tbody.getElementsByTagName('tr');
            const searchCount = document.getElementById('searchCount');

            // Đếm tổng số sản phẩm ban đầu
            const totalProducts = rows.length - (rows[rows.length - 1].innerText.includes('Chưa có sản phẩm') ? 1 : 0);

            // Hiển thị tổng số sản phẩm ban đầu
            updateSearchCount(totalProducts, totalProducts);

            searchInput.addEventListener('keyup', function () {
                const searchTerm = this.value.toLowerCase().trim();
                let visibleCount = 0;

                for (let i = 0; i < rows.length; i++) {
                    const row = rows[i];

                    // Bỏ qua dòng "Chưa có sản phẩm"
                    if (row.cells.length === 1) continue;

                    const productName = row.cells[1].textContent.toLowerCase();

                    if (productName.includes(searchTerm)) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                }

                // Cập nhật số lượng kết quả
                updateSearchCount(visibleCount, totalProducts);
            });

            function updateSearchCount(visible, total) {
                if (searchInput.value.trim() === '') {
                    searchCount.textContent = `Hiển thị tất cả ${total} sản phẩm`;
                } else {
                    searchCount.textContent = `Tìm thấy ${visible} / ${total} sản phẩm`;
                }
            }
        });
    </script>
</body>

</html>